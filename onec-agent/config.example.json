  "automation": {
    "enabled": true,
    "perStepDelayMs": 400,
    "screenshotOnError": true,
    "forceEnglishLayout": true,
    "keyboardLayoutKlid": "00000409",
    "minimizeAgentConsole": true,
    "forceFocusBeforeKeys": true,
    "clickBeforeKeys": false,
    "clickBeforeSave": false,
    "dismissMenuAfterRefocus": true,
    "dismissFieldPicker": true,
    "windowActivateClick": null,
    "reportClick": { "x": 700, "y": 450 },
    "formWaitMs": 35000,
    "saveRetry": { "maxAttempts": 18, "intervalMs": 5000 },
    "saveOpenAttempts": [
      { "label": "Ctrl+S", "keys": ["LeftControl", "S"], "waitMs": 3500 },
      { "label": "Ctrl+Shift+S (Сохранить как)", "keys": ["LeftControl", "LeftShift", "S"], "waitMs": 3500 },
      { "label": "кнопка на панелі", "toolbar": true, "waitMs": 3500 }
    ],
    "toolbarSaveClick": null,
    "steps": [
      { "action": "comment", "text": "=== 1. Сформировать ===" },
      { "action": "focusWindow", "dialog": "main", "titleContains": ["Ведомость", "Предприятие"] },
      { "action": "wait", "ms": 500 },
      { "action": "key", "keys": ["LeftControl", "Enter"], "skipRefocus": true },

      { "action": "comment", "text": "=== 2. Чекати звіт + Сохранение ===" },
      { "action": "retryOpenSave", "minWaitMs": 35000, "maxAttempts": 18, "intervalMs": 5000, "clickReport": false },

      { "action": "comment", "text": "=== 3. Шлях файлу + зберегти (тип за замовчуванням) ===" },
      { "action": "focusWindow", "dialog": "save", "preferShort": true, "titleContains": ["Сохранение", "Сохранить", "Збереження"] },
      { "action": "wait", "ms": 800 },
      { "action": "key", "keys": ["LeftControl", "A"] },
      { "action": "wait", "ms": 200 },
      { "action": "paste", "text": "{{filePath}}", "focusAfterClipboard": { "dialog": "save", "preferShort": true, "titleContains": ["Сохранение", "Сохранить"] } },
      { "action": "wait", "ms": 400 },
      { "action": "key", "keys": ["Enter"] },

      { "action": "wait", "ms": 5000 }
    ]
  }
