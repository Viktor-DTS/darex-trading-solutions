      { "action": "key", "keys": ["LeftControl", "A"] },
      { "action": "wait", "ms": 200 },
      { "action": "paste", "text": "{{filePath}}", "focusAfterClipboard": { "dialog": "save", "preferShort": true, "titleContains": ["Сохранение", "Сохранить"] } },
