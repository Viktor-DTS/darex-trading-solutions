      { "action": "key", "keys": ["LeftControl", "Enter"] },

      { "action": "comment", "text": "=== 2. Чекати звіт + Сохранение ===" },
      { "action": "retryOpenSave", "minWaitMs": 35000, "maxAttempts": 18, "intervalMs": 5000 },

      { "action": "comment", "text": "=== 3. Шлях файлу + зберегти (тип за замовчуванням) ===" },
