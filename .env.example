# ── Mode: intraday (1m–5m) | scalp (tick stream, needs broker) ──

FX_MODE=intraday

# One pair (legacy) or comma-separated list (40 majors + crosses on Yahoo):

FX_PAIR=EURUSD

FX_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF,NZDUSD,USDCNH,EURGBP,EURJPY,GBPJPY,AUDJPY,EURCHF,GBPAUD,GBPCHF,EURAUD,EURNZD,CADJPY,AUDCAD,NZDJPY,CHFJPY,AUDNZD,EURCAD,GBPCAD,GBPNZD,AUDCHF,NZDCHF,CADCHF,NZDCAD,EURTRY,EURHUF,EURSEK,EURNOK,USDNOK,USDSGD,USDHKD,USDPLN,USDMXN,USDZAR

# Optional: comma-separated pairs to exclude from trading (empty = all FX_PAIRS active)
# FX_PAIR_BLACKLIST=EURCHF



# Worker loop — ms between ticks (1000 = 1 sec; use 100–500 when on OANDA stream)

FX_TICK_MS=1000

# Fast open-position monitor (ms). 0 = same as FX_TICK_MS (1s with default tick).
FX_OPEN_MONITOR_MS=0

# Broker sync interval during open monitor (detect manual closes). Default 5000ms.
FX_OPEN_BROKER_SYNC_MS=5000



# Heartbeat log interval in worker (ms)

FX_TICK_LOG_MS=30000



# Analyze cycle gap (ms). 0 = auto from pair count (~20s for 40 pairs)

FX_ANALYZE_GAP_MS=0



# Parallel Yahoo refresh batch size

FX_PAIR_REFRESH_CONCURRENCY=8



# Market data: yahoo | oanda (oanda needs FX_OANDA_TOKEN)

FX_DATA_PROVIDER=yahoo



# OANDA paper (practice account, free) — real fills + real spread
# Рекомендація для 40 пар: дані лишити на Yahoo (FX_DATA_PROVIDER=yahoo),
# а на OANDA перевести лише виконання (FX_EXECUTOR=oanda).
# Крок 1: реєстрація practice → https://www.oanda.com/  (demo/practice account)
# Крок 2: Manage API Access → Generate token
# Крок 3: скопіювати Account ID (формат 101-004-XXXXXXX-001)
# Крок 4: заповнити 3 змінні нижче + FX_EXECUTOR=oanda, потім `npm run oanda:check`

# FX_OANDA_TOKEN=your-practice-api-token

# FX_OANDA_ACCOUNT=101-004-XXXXXXX-001

# FX_OANDA_ENV=practice

# FX_EXECUTOR=oanda      # sim (default) | oanda (paper on practice) | auto
# FX_DATA_PROVIDER=yahoo # для 40 пар лишити yahoo; oanda-стрім лише 1 пара

# ── Capital.com paper (demo, безкоштовно, ДОСТУПНО в Україні) — рекомендований шлях ──
# REST API працює прямо з Render, дані лишаємо на Yahoo, виконання — Capital.
# Крок 1: реєстрація demo → https://capital.com/ (demo account з реальними цінами)
# Крок 2: увімкнути 2FA (обовʼязково перед генерацією ключа)
# Крок 3: Settings → API integrations → Generate new key (задати custom API password!)
# Крок 4: заповнити 4 змінні + FX_EXECUTOR=capital, потім `npm run capital:check`

# FX_CAPITAL_API_KEY=your-generated-api-key
# FX_CAPITAL_IDENTIFIER=your-account-email@example.com
# FX_CAPITAL_PASSWORD=your-custom-api-password   # НЕ логін-пароль, а окремий API password
# FX_CAPITAL_ENV=demo            # demo | live
# FX_EXECUTOR=capital            # sim | oanda | capital | auto
# FX_DATA_PROVIDER=capital       # рекомендовано з FX_EXECUTOR=capital — ті самі bid/ask що при угоді
# FX_DATA_PROVIDER=yahoo         # fallback: дані Yahoo, виконання Capital
# Калібрування розміру (за потреби, після capital:check):
# FX_CAPITAL_CONTRACT_SIZE=0     # units per 1 size (0 = взяти з ринку lotSize)
# FX_CAPITAL_MIN_SIZE=0          # мін. розмір угоди (0 = взяти з dealingRules)
# Capital data rate limits (demo ~1000 req/hour):
# FX_CAPITAL_USE_WEBSOCKET=1     # 1 (default) — real-time bid/ask + OHLC via WebSocket (до 40 пар)
# FX_CAPITAL_WS_BOOTSTRAP_PAIRS=5  # REST bars лише для N пар при старті (0 = без bootstrap)
# FX_CAPITAL_YAHOO_FALLBACK=1      # під час 429 — дані з Yahoo, аналіз не зупиняється
# FX_CAPITAL_RATE_LIMIT_POLL_MS=60000  # retry Capital WS кожні 60с (не чекати повні 300с)
# FX_CAPITAL_STREAM_PING_MS=300000  # ping кожні 5 хв (Capital вимагає ~10 хв max)
# FX_CAPITAL_QUOTE_BATCH=1       # лише fallback REST, якщо WS недоступний
# FX_CAPITAL_BAR_REFRESH_MS=300000
# FX_CAPITAL_HYDRATE_DELAY_MS=8000



# Twelve Data optional fallback

# FX_TWELVE_DATA_KEY=



# Risk

FX_EQUITY_USD=1000

FX_RISK_PER_TRADE_PCT=0.5

FX_DAILY_LOSS_LIMIT_PCT=1.5

FX_MAX_TRADES_PER_DAY=50

FX_MAX_OPEN_POSITIONS=8

FX_MAX_SPREAD_PIPS=2.0

# Pair tiers — tier1 always in session; tier2 only overlap 12–16 UTC (spread ≤ FX_PAIR_TIER2_MAX_SPREAD)
# FX_PAIR_TIER1=EURUSD,GBPUSD,USDJPY,...
FX_PAIR_TIER2_MAX_SPREAD=3
FX_PAIR_TIER2_MIN_BUY_SCORE=68

# 5m trend: min ADX to leave range/chop (default 18)
FX_REGIME_MIN_ADX=18



# Targets (intraday MVP)
# With FX_PROFIT_BOOST=1 defaults become TP=5 / SL=4 (better R:R)

FX_TARGET_PIPS=4

FX_STOP_PIPS=5

FX_MIN_PROFIT_SL_PCT=25

# Profit Boost package
FX_PROFIT_BOOST=1
FX_PAIR_MAX_TRADES_DAY=3
FX_PAIR_COOLDOWN_SL_MS=1800000
FX_MIN_SELL_SCORE=72
FX_POST_NEWS_BOOST=1
FX_POST_NEWS_BOOST_CONV=8
FX_POST_NEWS_BOOST_THRESHOLD=3
FX_POST_NEWS_BOOST_WINDOW_MS=5400000



# Sessions (UTC) — London open, NY overlap

FX_SESSION_START_UTC=07:00

FX_SESSION_END_UTC=17:00



# API (optional dashboard)

FX_API_PORT=8787

# Render / remote: Render sets PORT; optional shared secret for API proxy
# FX_API_SECRET=your-long-random-secret
# FX_PANEL_USER=admin
# FX_PANEL_PASSWORD=your-strong-password
# FX_PAIR_BLACKLIST=EURCHF
# FX_PAIR_WHITELIST=EURUSD,EURGBP,GBPUSD
# FX_BREAKEVEN=1
# FX_BREAKEVEN_PIPS=2
# FX_WATCH_AUTO_ENTRY=1
# FX_WATCH_AUTO_ENTRY_CYCLES=2
# FX_TRADE_TELEGRAM=1
# FX_LEARN_TELEGRAM=1
# FX_TELEGRAM_BOT_TOKEN=123456:ABC...   (from @BotFather)
# FX_TELEGRAM_CHAT_ID=716206021



# Dev only (Windows TLS) — do NOT use on VPS

# FX_TLS_INSECURE=1



# Filters

FX_NEWS_BLACKOUT=1

FX_DXY_FILTER=1

FX_HTF_FILTER=1

FX_MAX_EXPOSURE_PER_CURRENCY=2

FX_ALLOW_SHORT=1
FX_BIDIRECTIONAL=1
FX_BIDIRECTIONAL_HTF=1
FX_BALANCE_DIRECTIONS=1

# Layer engine v2 — macro + 1h + 5m + 1m (потрібно 3/4)
FX_MIN_BUY_SCORE=68
FX_MIN_LAYERS_ALIGNED=3
FX_MACRO_FILTER=1
FX_LAYER_ENGINE=1
FX_JPY_FILTER=1
FX_MAX_JPY_CROSS=2
FX_VOLATILITY_RATIO=1.45
FX_MACRO_CACHE_MS=120000

# Economic calendar + CPI/NFP surprise
FX_CALENDAR=1
FX_CALENDAR_PROVIDER=forexfactory
FX_CALENDAR_CACHE_MS=900000
FX_CALENDAR_BLACKOUT_BEFORE_MIN=5
FX_CALENDAR_BLACKOUT_AFTER_MIN=15
FX_CALENDAR_SURPRISE=1
FX_CALENDAR_SURPRISE_HALFLIFE_MS=14400000
# FX_FINNHUB_API_KEY=  (FX_CALENDAR_PROVIDER=finnhub)

# Smart mode — Ideal Formula v3 (fundamentals + technical)
FX_SMART_MODE=1
FX_FUNDAMENTAL_ENGINE=1
FX_SMART_MAX_ENTRIES_CYCLE=3
FX_SMART_PAIR_PAUSE_SL=3

FX_PAIR_COOLDOWN_MS=900000
FX_PAIR_COOLDOWN_TP_MS=1800000
FX_REQUIRE_MOMENTUM=1

