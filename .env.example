# ── ORACLE-5m — mandatory 5-minute forecast before testbot entry ──
FX_ORACLE_5M=1
FX_ORACLE_HORIZON_SEC=300
FX_ORACLE_MIN_P_UP=0.55
FX_ORACLE_MIN_KAPPA=0.55
FX_ORACLE_MIN_P_TP=0.52
FX_ORACLE_TRADE=1
FX_ORACLE_RESPECT_INVERT=1
FX_ORACLE_LOG=oracle-forecasts.jsonl
FX_ORACLE_ACTUAL_LOG=oracle-actual.jsonl
FX_ORACLE_TOXIC_WR=0.40
FX_ORACLE_TOXIC_MIN_TRADES=10
FX_ORACLE_MIN_STATS_SAMPLES=30
FX_ORACLE_MIN_DIRECTION_HIT=0.52
FX_ORACLE_MIN_PAIR_HIT=0.50
FX_ORACLE_STATS_WINDOW=200
FX_ORACLE_WINDOW_BARS=36
FX_ORACLE_MC_PATHS=500
FX_ORACLE_MICRO_BARS=1.5
# Testbot-only oracle overrides ($3 SL + flip)
FX_TESTBOT_ORACLE_MICRO_BARS=0.35
FX_TESTBOT_ORACLE_MIN_P_UP=0.48
FX_TESTBOT_ORACLE_MIN_KAPPA=0.50
FX_TESTBOT_ORACLE_MIN_P_TP=0.48
FX_TESTBOT_ORACLE_SOFT_DIR=1
FX_TESTBOT_ORACLE_MIN_DIRECTION_HIT=0.45
FX_TESTBOT_ORACLE_MICRO_M1=1.5

# Θ math ensemble (CHARLIE live gate)
# FX_MATH_GATE=1
# FX_MATH_THETA=1
# FX_MATH_MIN_KAPPA=0.55
# FX_MATH_MAX_JUMP=0.35
# FX_MATH_MICRO_BARS=1.5

# FX_POSITION_MGMT=0
# FX_SCALP_MODE=0
# FX_BREAKEVEN=1
# FX_BREAKEVEN_PIPS=4

# Scalp quick profile — tier-1, overlap sessions, tight TP/SL
FX_SCALP_MODE=1
FX_SCALP_TIER1_ONLY=1
FX_SCALP_SESSIONS=london,overlap,overlap_late
FX_TARGET_PIPS=3
FX_STOP_PIPS=3
FX_MIN_BUY_SCORE=72
FX_MIN_SELL_SCORE=74
FX_PAIR_TIER2_MIN_BUY_SCORE=72

# Active position management — conv decay, time scratch, good-enough exit
FX_POSITION_MGMT=1
FX_POS_CONV_DECAY=15
FX_POS_PROFIT_DECAY_CONV=10
FX_POS_TP_DECAY_CONV=8
FX_POS_MIN_PROFIT_PIPS=0.5
FX_POS_GOOD_ENOUGH_TP_PIPS=0.5
FX_POS_PULLBACK_PIPS=0.3
FX_POS_TIME_SCRATCH_MS=300000
FX_POS_TIME_MAX_MS=600000
FX_POS_PROGRESS_PIPS=0.5
FX_POS_DYNAMIC_TP=1
FX_BREAKEVEN_BROKER=1

# Execution: sim (default) | oanda paper | auto (oanda when FX_SIMULATE=0 + tokens)
FX_EXECUTOR=sim
# FX_SIMULATE=0
# FX_OANDA_TOKEN=your-practice-api-token
# FX_OANDA_ACCOUNT=your-practice-account-id
# FX_OANDA_ENV=practice
# FX_DATA_PROVIDER=oanda

FX_STATE_FILE=1



# Learning module (self-tune from journal)

FX_LEARN_MIN_TRADES=5

FX_LEARN_INTERVAL_MS=86400000

FX_LEARN_TELEGRAM=1

# FX_TELEGRAM_BOT_TOKEN=  (or reuse TELEGRAM_BOT_TOKEN)

# FX_TELEGRAM_CHAT_ID=



# Simulate execution (no broker)

FX_SIMULATE=1

FX_SIM_RISK_SIZING=1

FX_SIM_SPREAD_PIPS=1.2

FX_SIM_COMMISSION_USD=0.05

# Реалізм симуляції (щоб журнал був чеснішим без брокера):
# проковзування ринкового входу (pips, гірше за котирування)
FX_SIM_SLIPPAGE_PIPS=0.2
# проковзування на стоп-лосі (стоп заповнюється гірше рівня, як у реалі)
FX_SIM_STOP_SLIPPAGE_PIPS=0.5
# множник розширення спреду поза піком (quiet/ny_close/extended/overlap_late)
FX_SIM_SPREAD_SESSION_MULT=1.4

# FX_SIM_SPREADS=EURUSD:1.0,EURNZD:2.5

