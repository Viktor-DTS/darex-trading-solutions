# ── Mode: intraday (1m–5m) | scalp (tick stream, needs broker) ──

FX_MODE=intraday

# One pair (legacy) or comma-separated list (up to ~20 on Yahoo):

FX_PAIR=EURUSD

FX_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF,NZDUSD,EURGBP,EURJPY,GBPJPY,AUDJPY,EURCHF,GBPAUD,GBPCHF,EURAUD,EURNZD,CADJPY,AUDCAD,NZDJPY,CHFJPY



# Worker loop — ms between ticks (1000 = 1 sec; use 100–500 when on OANDA stream)

FX_TICK_MS=1000



# Heartbeat log interval in worker (ms)

FX_TICK_LOG_MS=30000



# Analyze cycle gap (ms). 0 = auto from pair count (~10s for 20 pairs)

FX_ANALYZE_GAP_MS=0



# Parallel Yahoo refresh batch size

FX_PAIR_REFRESH_CONCURRENCY=5



# Market data: yahoo | oanda (oanda needs FX_OANDA_TOKEN)

FX_DATA_PROVIDER=yahoo



# OANDA (phase 2 — demo account, free)

# FX_OANDA_TOKEN=your-practice-api-token

# FX_OANDA_ACCOUNT=your-practice-account-id

# FX_OANDA_ENV=practice



# Twelve Data optional fallback

# FX_TWELVE_DATA_KEY=



# Risk

FX_EQUITY_USD=1000

FX_RISK_PER_TRADE_PCT=0.25

FX_DAILY_LOSS_LIMIT_PCT=1.5

FX_MAX_TRADES_PER_DAY=50

FX_MAX_OPEN_POSITIONS=8

FX_MAX_SPREAD_PIPS=1.5



# Targets (intraday MVP)
# With FX_PROFIT_BOOST=1 defaults become TP=5 / SL=4 (better R:R)

FX_TARGET_PIPS=4

FX_STOP_PIPS=5

FX_MIN_PROFIT_SL_PCT=25

# Profit Boost package
FX_PROFIT_BOOST=1
FX_PAIR_MAX_TRADES_DAY=2
FX_PAIR_COOLDOWN_SL_MS=1800000
FX_MIN_SELL_SCORE=75
FX_POST_NEWS_BOOST=1
FX_POST_NEWS_BOOST_CONV=8
FX_POST_NEWS_BOOST_THRESHOLD=3
FX_POST_NEWS_BOOST_WINDOW_MS=5400000



# Sessions (UTC) — London open, NY overlap

FX_SESSION_START_UTC=07:00

FX_SESSION_END_UTC=20:00



# API (optional dashboard)

FX_API_PORT=8787

# Render / remote: Render sets PORT; optional shared secret for API proxy
# FX_API_SECRET=your-long-random-secret
# FX_AUTO_START_WORKER=1
# FX_CORS_ORIGINS=https://darex-trading-solutions-f.onrender.com



# Dev only (Windows TLS) — do NOT use on VPS

# FX_TLS_INSECURE=1



# Filters

FX_NEWS_BLACKOUT=1

FX_DXY_FILTER=1

FX_HTF_FILTER=1

FX_MAX_EXPOSURE_PER_CURRENCY=2

FX_ALLOW_SHORT=1
FX_BIDIRECTIONAL=1
FX_BIDIRECTIONAL_HTF=1
FX_BALANCE_DIRECTIONS=1

# Layer engine v2 — macro + 1h + 5m + 1m (потрібно 3/4)
FX_MIN_BUY_SCORE=85
FX_MIN_LAYERS_ALIGNED=3
FX_MACRO_FILTER=1
FX_LAYER_ENGINE=1
FX_JPY_FILTER=1
FX_MAX_JPY_CROSS=1
FX_VOLATILITY_RATIO=1.45
FX_MACRO_CACHE_MS=120000

# Economic calendar + CPI/NFP surprise
FX_CALENDAR=1
FX_CALENDAR_PROVIDER=forexfactory
FX_CALENDAR_CACHE_MS=900000
FX_CALENDAR_BLACKOUT_BEFORE_MIN=5
FX_CALENDAR_BLACKOUT_AFTER_MIN=15
FX_CALENDAR_SURPRISE=1
FX_CALENDAR_SURPRISE_HALFLIFE_MS=14400000
# FX_FINNHUB_API_KEY=  (FX_CALENDAR_PROVIDER=finnhub)

# Smart mode — Ideal Formula v3 (fundamentals + technical)
FX_SMART_MODE=1
FX_FUNDAMENTAL_ENGINE=1
FX_SMART_MAX_ENTRIES_CYCLE=2
FX_SMART_PAIR_PAUSE_SL=3

FX_PAIR_COOLDOWN_MS=900000
FX_PAIR_COOLDOWN_TP_MS=300000
FX_REQUIRE_MOMENTUM=1

# Execution: sim (default) | oanda paper | auto (oanda when FX_SIMULATE=0 + tokens)
FX_EXECUTOR=sim
# FX_SIMULATE=0
# FX_OANDA_TOKEN=your-practice-api-token
# FX_OANDA_ACCOUNT=your-practice-account-id
# FX_OANDA_ENV=practice
# FX_DATA_PROVIDER=oanda

FX_STATE_FILE=1



# Learning module (self-tune from journal)

FX_LEARN_MIN_TRADES=5

FX_LEARN_INTERVAL_MS=86400000

FX_LEARN_TELEGRAM=1

# FX_TELEGRAM_BOT_TOKEN=  (or reuse TELEGRAM_BOT_TOKEN)

# FX_TELEGRAM_CHAT_ID=



# Simulate execution (no broker)

FX_SIMULATE=1

FX_SIM_RISK_SIZING=1

FX_SIM_SPREAD_PIPS=1.2

FX_SIM_COMMISSION_USD=0.05

# FX_SIM_SPREADS=EURUSD:1.0,EURNZD:2.5

