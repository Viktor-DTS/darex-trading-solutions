# MongoDB Connection
MONGODB_URI=mongodb+srv://darexuser:viktor22@cluster0.yaec2av.mongodb.net/test?retryWrites=true&w=majority&appName=Cluster0

# Окремий кластер MongoDB лише для асистента (наприклад Atlas M0 / DTSBackup)
# Ім'я бази в URI — ваше (наприклад assistant): ...mongodb.net/assistant?retryWrites=true&w=majority
# ASSISTANT_MONGODB_URI=mongodb+srv://ASSIST_USER:PASSWORD@cluster.xxxxx.mongodb.net/assistant?retryWrites=true&w=majority

# Чат-асистент (GPT): за замовчуванням той самий ключ/база що PRODUCT_ASSISTANT_LLM_* або OPENAI_API_KEY
# ASSISTANT_CHAT_MODEL=gpt-4o-mini
# ASSISTANT_CHAT_BASE_URL=https://api.openai.com/v1
# ASSISTANT_CHAT_TIMEOUT_MS=60000
# ASSISTANT_CHAT_MAX_TOKENS=2048
# ASSISTANT_CHAT_TEMPERATURE=0.4

# JWT Secret
JWT_SECRET=your-secret-key-change-in-production

# Server Port
PORT=3001

# Environment
NODE_ENV=development

# Cloudinary (для завантаження файлів)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google APIs
# GOOGLE_GEOCODING_API_KEY - використовується для геокодування та OCR (Google Vision API)
# GOOGLE_VISION_API_KEY - опціонально, якщо потрібен окремий ключ для Vision API
# Якщо GOOGLE_VISION_API_KEY не встановлено, буде використано GOOGLE_GEOCODING_API_KEY
GOOGLE_GEOCODING_API_KEY=your_google_api_key

# Асистент карточки продукту — SerpApi (Render → Environment на бекенд-сервісі darex-trading-solutions)
# Ключ: https://serpapi.com/manage-api-key
# SERPAPI_API_KEY=your_serpapi_key
# PRODUCT_ASSISTANT_SERPAPI_IMAGE_SEARCH=1
# PRODUCT_ASSISTANT_SERPAPI_SPEC_SEARCH=1
# (якщо SERPAPI_API_KEY заданий, spec search увімкнеться і без PRODUCT_ASSISTANT_SERPAPI_SPEC_SEARCH; 0 — вимкнути)
# PRODUCT_ASSISTANT_LLM_API_KEY=... або OPENAI_API_KEY=... (той самий ключ, що чат-асистент)