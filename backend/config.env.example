# MongoDB Connection
MONGODB_URI=mongodb+srv://darexuser:viktor22@cluster0.yaec2av.mongodb.net/test?retryWrites=true&w=majority&appName=Cluster0

# Окремий кластер MongoDB лише для асистента (наприклад Atlas M0 / DTSBackup)
# Ім'я бази в URI — ваше (наприклад assistant): ...mongodb.net/assistant?retryWrites=true&w=majority
# ASSISTANT_MONGODB_URI=mongodb+srv://ASSIST_USER:PASSWORD@cluster.xxxxx.mongodb.net/assistant?retryWrites=true&w=majority

# Чат-асистент (GPT): за замовчуванням той самий ключ/база що PRODUCT_ASSISTANT_LLM_* або OPENAI_API_KEY
# ASSISTANT_CHAT_MODEL=gpt-4o-mini
# ASSISTANT_CHAT_BASE_URL=https://api.openai.com/v1
# ASSISTANT_CHAT_TIMEOUT_MS=60000
# ASSISTANT_CHAT_MAX_TOKENS=2048
# ASSISTANT_CHAT_TEMPERATURE=0.4

# ── Trading module (IBKR capital growth, Render + assistant MongoDB) ──
# TRADING_MODULE_ENABLED=1
# TRADING_SCAN_ENABLED=1          # setInterval scan on backend (also use Render Cron below)
# TRADING_SCAN_INTERVAL_MS=3600000
# TRADING_CRON_SECRET=change-me-long-random   # Render Cron → POST /api/trading/cron/scan + header X-Trading-Cron-Secret
# TRADING_CRON_URL=https://darex-trading-solutions.onrender.com/api/trading/cron/scan
# TRADING_TELEGRAM_NOTIFY=1
# TRADING_TELEGRAM_BUY_ONLY=1                 # 1 = лише BUY алерти (рекомендовано)
# TRADING_TELEGRAM_CHAT_ID=123456789
# TRADING_CHART_CACHE_MS=2700000
# TRADING_FETCH_GAP_MS=1500
# TRADING_SIM_COMMISSION_USD=1        # комісія за сторону у режимі simulate (або simCommissionPerSideUsd в UI)
# IBKR OAuth (First-party — Self-Service Portal)
# https://ndcdyn.interactivebrokers.com/sso/Login?action=OAUTH
# IBKR_CONSUMER_KEY=          # 9 символів з порталу
# IBKR_ACCESS_TOKEN=           # з порталу
# IBKR_ACCESS_SECRET_HEX=      # decrypted hex (openssl pkeyutl -decrypt … | xxd -p -c 0)
# IBKR_SIGNATURE_PRIVATE_KEY_B64=  # PKCS8 private key, base64 (openssl pkcs8 -topk8 -nocrypt …)
# IBKR_DH_PRIME_HEX=           # prime з dhparam.pem (див. README @quentinadam/ibkr)
# IBKR_REALM=limited_poa       # test_realm для TESTCONS
# IBKR_ACCOUNT_ID=             # paper DU… або live U…
# IBKR_LIVE_ORDERS=0           # 1 = відправляти bracket-ордери
# IBKR sync: після скану оновлює fills/комісію/P/L з /iserver/account/trades (~7 днів)
# IBKR_API_BASE=https://api.ibkr.com/v1/api

# JWT Secret
JWT_SECRET=your-secret-key-change-in-production

# Server Port
PORT=3001

# Environment
NODE_ENV=development

# Cloudinary (для завантаження файлів)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google APIs
# GOOGLE_GEOCODING_API_KEY - використовується для геокодування та OCR (Google Vision API)
# GOOGLE_VISION_API_KEY - опціонально, якщо потрібен окремий ключ для Vision API
# Якщо GOOGLE_VISION_API_KEY не встановлено, буде використано GOOGLE_GEOCODING_API_KEY
GOOGLE_GEOCODING_API_KEY=your_google_api_key

# Асистент карточки продукту — SerpApi (Render → Environment на бекенд-сервісі darex-trading-solutions)
# Ключ: https://serpapi.com/manage-api-key
# SERPAPI_API_KEY=your_serpapi_key
# PRODUCT_ASSISTANT_SERPAPI_IMAGE_SEARCH=1
# PRODUCT_ASSISTANT_SERPAPI_SPEC_SEARCH=1
# (якщо SERPAPI_API_KEY заданий, spec search увімкнеться і без PRODUCT_ASSISTANT_SERPAPI_SPEC_SEARCH; 0 — вимкнути)
# PRODUCT_ASSISTANT_LLM_API_KEY=... або OPENAI_API_KEY=... (той самий ключ, що чат-асистент)